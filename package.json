    "class-validator": "^0.14.4",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dataloader": "^2.2.3",
    "dayjs": "^1.11.20",
    "graphql": "^16.13.1",
    "mysql2": "^3.20.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "qcloud-cos-sts": "^3.1.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "tencentcloud-sdk-nodejs": "^4.1.200",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "^24.12.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "30.1.3",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "29.4.1",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@/libs/passport(|/.*)$": "<rootDir>/libs/passport/src/$1",
      "^@/libs/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@/libs/mercury-client(|/.*)$": "<rootDir>/libs/mercury-client/src/$1",
      "^@/libs/pluto-client(|/.*)$": "<rootDir>/libs/pluto-client/src/$1",
      "^@/libs/cache(|/.*)$": "<rootDir>/libs/cache/src/$1"
    }
  }
}
