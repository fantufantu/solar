  "private": true,
  "license": "MIT",
  "scripts": {
    "dev:pluto": "nest start pluto --watch",
    "dev:mercury": "nest start mercury --watch",
    "dev:venus": "nest start venus --watch",
    "dev:earth": "nest start earth --watch",
    "dev:mars": "nest start mars --watch",
    "dev:halley": "nest start halley --watch",
    "build:pluto": "nest build pluto",
    "build:mercury": "nest build mercury",
    "build:venus": "nest build venus",
    "build:earth": "nest build earth",
    "build:mars": "nest build mars",
    "build:halley": "nest build halley",
    "start:pluto": "nest start pluto",
    "start:mercury": "nest start mercury",
    "start:venus": "nest start venus",
    "start:earth": "nest start earth",
    "start:mars": "nest start mars",
    "start:halley": "nest start halley"
  },
  "dependencies": {
    "@aiszlab/relax": "2.0.8-beta.4",
    "@apollo/gateway": "^2.13.3",
    "@apollo/server": "^4.13.0",
    "@apollo/subgraph": "^2.13.3",
    "@google-analytics/data": "^5.2.1",
    "@langchain/core": "^1.1.35",
    "@langchain/openai": "^1.3.0",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.17",
